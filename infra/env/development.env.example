COMPOSE_PROJECT_NAME=expertbase-development
PROJECT_ENV=development

POSTGRES_DB=expertbase
POSTGRES_USER=expertbase
POSTGRES_PASSWORD=expertbase
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=expertbase
MINIO_ROOT_PASSWORD=expertbase-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=expertbase

TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8081
TRAEFIK_HOST=traefik.expertbase.localhost
APP_HOST=expertbase.test
API_PATH_PREFIX=/api
MINIO_HOST=minio.expertbase.localhost

APP_ENV=development
APP_NAME=Expert Base API
BACKEND_PORT=8000
BACKEND_COMMAND=uv run uvicorn main:app --host 0.0.0.0 --port 8000

FRONTEND_PORT=3000
FRONTEND_COMMAND=bun install && bun run dev --hostname 0.0.0.0
NEXT_PUBLIC_API_BASE_URL=http://expertbase.test/api
