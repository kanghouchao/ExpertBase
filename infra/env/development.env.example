COMPOSE_PROJECT_NAME=expertbase-development
PROJECT_ENV=development

POSTGRES_DB=expertbase
POSTGRES_USER=expertbase
POSTGRES_PASSWORD=expertbase
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=expertbase
MINIO_ROOT_PASSWORD=expertbase-secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=expertbase

TRAEFIK_HTTP_PORT=8080
TRAEFIK_DASHBOARD_PORT=8081
APP_HOST=expertbase.localhost
API_HOST=api.expertbase.localhost
MINIO_HOST=minio.expertbase.localhost

APP_ENV=development
APP_NAME=Expert Base API
BACKEND_PORT=8000
BACKEND_COMMAND=uv run python main.py

FRONTEND_PORT=3000
FRONTEND_COMMAND=bun run dev --hostname 0.0.0.0
NEXT_PUBLIC_API_BASE_URL=http://api.expertbase.localhost:8080
